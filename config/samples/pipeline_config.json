{
  "max_workers": 4,
  "batch_size": 10,
  "timeout_seconds": 600,
  "document_processing": {
    "chunking_strategy": "token_based_with_overlap",
    "chunk_token_size": 1200,
    "chunk_overlap_token_size": 100,
    "max_chunk_token_size": 2048,
    "tokenizer": "tiktoken",
    "tiktoken_model": "gpt-4o-mini",
    "supported_formats": ["pdf", "docx", "pptx", "txt", "md"],
    "preserve_page_context": true,
    "chunk_top_k": 6
  },
  "image_processing": {
    "max_image_size_mb": 10,
    "resize_threshold": 4096,
    "quality": 95,
    "blur_detection_threshold": 100
  },
  "parallel_processing": {
    "enabled": true,
    "max_concurrent_docs": 5,
    "max_concurrent_images": 10
  },
  "retry_policy": {
    "max_retries": 3,
    "backoff_factor": 2,
    "initial_delay_seconds": 1
  },
  "notification": {
    "enabled": true,
    "mmkg_ready_webhook": null,
    "error_webhook": null
  }
}